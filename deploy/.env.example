# =========================================================================
# Plantilla de despliegue. Copia a `.env` y rellena los CAMBIAR con secretos
# propios. NUNCA subas el .env real a git (está en .gitignore).
#
# Genera los secretos:
#   SECRET_KEY           ->  python -c "import secrets; print(secrets.token_hex(32))"
#   FIELD_ENCRYPTION_KEY ->  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   contraseñas          ->  python -c "import secrets; print(secrets.token_urlsafe(24))"
# =========================================================================

PROJECT_NAME=Sistema Inventario TI
LOG_LEVEL=INFO

# --- Base de datos ---
POSTGRES_USER=invuser
POSTGRES_PASSWORD=CAMBIAR
POSTGRES_DB=inventario

# --- Seguridad / JWT ---
SECRET_KEY=CAMBIAR_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Cifrado de campos sensibles (claves de licencia). OBLIGATORIO en producción.
FIELD_ENCRYPTION_KEY=CAMBIAR_Fernet_generate_key

BACKEND_CORS_ORIGINS=["https://localhost"]
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_DEFAULT=100/minute
PAGINATION_MAX_LIMIT=200

# --- Redis (caché de auth + rate-limit) ---
REDIS_PASSWORD=CAMBIAR_redis_password
REDIS_URL=redis://:CAMBIAR_redis_password@redis:6379/0
AUTH_CACHE_TTL_SECONDS=30

# --- Primer SUPER_ADMIN (bootstrap idempotente) ---
SUPER_ADMIN_USERNAME=sa
SUPER_ADMIN_EMAIL=admin@tu-dominio.com
SUPER_ADMIN_PASSWORD=CAMBIAR_password_fuerte

# --- Caddy / TLS ---
# DOMAIN=localhost      -> certificado autofirmado (dev)
# DOMAIN=tu.dominio.com -> Let's Encrypt automático (necesita 80/443 abiertos + DNS)
DOMAIN=localhost
ACME_EMAIL=admin@tu-dominio.com
HTTP_PORT=80
HTTPS_PORT=443

# --- Política de cuentas ---
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=10

# --- Datos de arranque ---
# IMPORTANTE: en producción SIEMPRE false. El seed mínimo canónico (estados
# operativos, tipos de movimiento, etc.) corre solo, sin data de demo.
# true SOLO en dev: carga personas/activos/usuarios DEMO de ejemplo.
SEED_DEMO=false

# --- SMTP / Email (opcional; si SMTP_HOST queda vacío, no se envían correos) ---
# Proveedores con free tier: Brevo (smtp-relay.brevo.com:587), SendGrid
# (smtp.sendgrid.net:587), Gmail (smtp.gmail.com:587, App Password), etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_STARTTLS=true
SMTP_FROM_EMAIL=noreply@tu-dominio.com
SMTP_FROM_NAME=Sistema Inventario
NOTIFY_ADMIN_EMAILS=
EMAIL_ENABLED=true

# === Ejemplo DEV con MailHog (captura local de correo) ===
# SMTP_HOST=mailhog
# SMTP_PORT=1025
# SMTP_STARTTLS=false
# SMTP_TLS=false
# (luego: docker compose --profile dev up -d  y abre http://localhost:8025)
